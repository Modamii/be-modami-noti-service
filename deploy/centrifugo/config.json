{
  "token_hmac_secret_key": "${CENTRIFUGO_HMAC_SECRET}",
  "api_key": "${CENTRIFUGO_API_KEY}",
  "admin": {
    "enabled": true,
    "password": "${CENTRIFUGO_ADMIN_PASSWORD}",
    "secret": "${CENTRIFUGO_ADMIN_SECRET}"
  },
  "engine": "redis",
  "redis_address": "redis:6379",
  "redis_password": "${REDIS_PASSWORD}",

  "proxy_connect_endpoint": "http://ws-gateway:8084/centrifugo/connect",
  "proxy_connect_timeout": "5s",

  "proxy_subscribe_endpoint": "http://ws-gateway:8084/centrifugo/subscribe",
  "proxy_subscribe_timeout": "3s",

  "proxy_publish_endpoint": "http://ws-gateway:8084/centrifugo/publish",
  "proxy_publish_timeout": "3s",

  "namespaces": [
    {
      "name": "notifications",
      "presence": true,
      "history_size": 50,
      "history_ttl": "300s",
      "recover": true,
      "proxy_subscribe": true,
      "proxy_publish": true
    }
  ],
  "allowed_origins": ["*"],
  "client_channel_limit": 128,
  "log_level": "info"
}
