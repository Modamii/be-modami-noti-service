# Copy this file to secret.yaml and fill in real values before applying.
# NEVER commit secret.yaml to git.
#
#   cp deploy/k8s/secret.yaml.example deploy/k8s/secret.yaml
#   kubectl apply -f deploy/k8s/secret.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: notification-secret
  namespace: techinsight-notifications
type: Opaque
stringData:
  MONGODB_URI: "mongodb://mongo:27017"
  REDIS_PASS: ""
  CENTRIFUGO_API_URL: "http://centrifugo:8000/api"
  CENTRIFUGO_API_KEY: "CHANGE_ME"
  CENTRIFUGO_HMAC_SECRET: "CHANGE_ME"
  CENTRIFUGO_ADMIN_PASSWORD: "CHANGE_ME"
  CENTRIFUGO_ADMIN_SECRET: "CHANGE_ME"
