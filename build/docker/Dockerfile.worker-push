FROM golang:1.23-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/worker-push ./cmd/worker-push

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /bin/worker-push /worker-push
COPY --from=builder /app/configs/config.yaml /app/configs/config.yaml
USER nonroot:nonroot
EXPOSE 9091
ENTRYPOINT ["/worker-push"]
