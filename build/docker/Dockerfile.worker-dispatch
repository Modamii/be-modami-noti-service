FROM golang:1.23-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/worker-dispatch ./cmd/worker-dispatch

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /bin/worker-dispatch /worker-dispatch
COPY --from=builder /app/configs/config.yaml /app/configs/config.yaml
USER nonroot:nonroot
EXPOSE 9090
ENTRYPOINT ["/worker-dispatch"]
