# Copy to .env and fill in values for local development.
# NEVER commit .env to git.
#
#   cp .env.example .env

# Centrifugo (local dev)
CENTRIFUGO_HMAC_SECRET=change-me-local-secret
CENTRIFUGO_API_KEY=change-me-api-key
CENTRIFUGO_ADMIN_PASSWORD=change-me-admin-password
CENTRIFUGO_ADMIN_SECRET=change-me-admin-secret

# MongoDB
MONGODB_URI=mongodb://localhost:27017/?directConnection=true

# Redis
REDIS_HOST=localhost
REDIS_PASS=
